
kscreen-doctor --dpms off # screen off, 

#dracut config ++ for overlay
root_uuid=$(findmnt -no UUID /) 
boot_uuid=$(findmnt -no UUID /boot)
k_ver=$(uname -r)
sudo tee /boot/grub2/custom.cfg << EOF
menuentry "fedora kde volatile overlay mode" --class fedora {
insmod gzio
insmod part_gpt
insmod ext2
search --no-floppy --fs-uuid --set=root $boot_uuid
linux /vmlinuz-$k_ver root=UUID=$root_uuid ro rootflags=subvol=root rhgb quiet systemd.volatile=overlay
initrd /initramfs-$k_ver.img
}
EOF
