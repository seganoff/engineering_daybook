{
  // =========================
  // EDITOR CORE SILENCE
  // =========================
  "editor.quickSuggestions": {
    "comments": "off",
    "strings": "off",
    "other": "off"
  }
, "editor.hover.enabled": false
, "editor.parameterHints.enabled": false
, "editor.codeLens": false
, "editor.lightbulb.enabled": "off"
, "editor.inlineSuggest.enabled": false
, "editor.autoIndent": "none"
, "editor.autoClosingBrackets": "never"
, "editor.autoClosingQuotes": "never"
, "editor.autoClosingComments": "never"
, "editor.formatOnSave": false
, "editor.formatOnType": false
, "editor.wordBasedSuggestions": "off"
, "editor.acceptSuggestionOnEnter": "off"
, "editor.suggestOnTriggerCharacters": false
, "editor.acceptSuggestionOnCommitCharacter": false
, "editor.autoSurround": "never"
, "editor.renderWhitespace": "all"
, "editor.fontFamily": "Menlo, Consolas, 'DejaVu Sans Mono', monospace"
, "editor.cursorWidth": 5

  // =========================
  // WORKBENCH / UI
  // =========================
, "workbench.startupEditor": "none"
, "workbench.editor.enablePreview": false
, "workbench.colorTheme": "Default High Contrast Light"

  // =========================
  // FILES / EXPLORER
  // =========================
, "files.autoGuessEncoding": false
//, "files.dialog.defaultPath": "<yourPATH>" //TODO edit here bofore applying
, "explorer.fileNesting.enabled": true
, "explorer.compactFolders": false
, "scm.compactFolders": false

  // =========================
  // LAUNCH / TASKS
  // =========================
, "launch": {}
, "taskExplorer.showLastTasks": false

  // =========================
  // C/C++ EXTENSION
  // =========================
, "C_Cpp.dimInactiveRegions": false
, "C_Cpp.configurationWarnings": "disabled"
, "C_Cpp.default.enableConfigurationSquiggles": false
, "C_Cpp.exclusionPolicy": "checkFilesAndFolders"
, "C_Cpp.autocomplete": "Disabled"
  // "C_Cpp.intelliSenseEngine": "disabled"

  // =========================
  // VIM EXTENSION
  // =========================
, "vim.easymotion": true
, "vim.incsearch": true
, "vim.useSystemClipboard": true
, "vim.useCtrlKeys": true
, "vim.hlsearch": true
, "vim.leader": "<space>"
, "vim.handleKeys": {
    "<C-a>": false
  , "<C-f>": false
  }
, "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"]
    , "after": ["<Esc>"]
    }
  ]
, "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"]
    , "after": ["d", "d"]
    }
  , {
      "before": ["<C-n>"]
    , "commands": [":nohl"]
    }
  , {
      "before": ["K"]
    , "commands": ["lineBreakInsert"]
    , "silent": true
    }
  ]

  // =========================
  // EXTENSIONS / SYSTEM
  // =========================
, "extensions.ignoreRecommendations": true
, "extensions.recommendations": false
, "extensions.autoCheckUpdates": false
, "extensions.autoUpdate": false
, "extensions.showRecommendationsOnlyOnDemand": true
, "telemetry.telemetryLevel": "off"
, "update.mode": "none"
, "update.showReleaseNotes": false

  // =========================
  // MARKDOWN / GIT
  // =========================
, "markdown.editor.updateLinksOnPaste.enabled": false
, "markdown.updateLinksOnFileMove.enableForDirectories": false
, "git.enabled": false

  // =========================
  // ACCESSIBILITY / NOTIFICATIONS
  // =========================
, "accessibility.verbosity.notification": false
, "zenMode.silentNotifications": true

  // =========================
  // SUGGESTION FILTERING
  // =========================
, "editor.suggest.showKeywords": false
, "editor.suggest.showMethods": false
, "editor.suggest.showFunctions": false
, "editor.suggest.showConstructors": false
, "editor.suggest.showFields": false
, "editor.suggest.showVariables": false
, "editor.suggest.showClasses": false
, "editor.suggest.showStructs": false
, "editor.suggest.showInterfaces": false
, "editor.suggest.showModules": false
, "editor.suggest.showProperties": false
, "editor.suggest.showEvents": false
, "editor.suggest.showOperators": false
, "editor.suggest.showUnits": false
, "editor.suggest.showValues": false
, "editor.suggest.showConstants": false
, "editor.suggest.showEnums": false
, "editor.suggest.showEnumMembers": false
, "editor.suggest.showSnippets": false

  // =========================
  // MISC
  // =========================
, "glassit.alpha": 195

  // =========================
  // VIM PERFORMANCE
  // =========================
, "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  }
}
//into keybindings.json
// Place your key bindings in this file to override the defaults
//[{ "key": "ctrl+shift+u","command": "insert-unicode.fromHexCode"},]

